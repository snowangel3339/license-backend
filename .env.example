# Copy this file to ".env" in the same folder (LicenseBackend-main).
# server.js loads: .env next to server.js

# --- MongoDB (required) ---
# Local:
MONGO_URI=mongodb://127.0.0.1:27017/license_manager
# Atlas example:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/license_db?retryWrites=true&w=majority

# --- Server ---
PORT=3000

# --- JWT (set JWT_SECRET in production) ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=1d

# --- Optional: signup gets admin if email is listed (comma-separated) ---
# ADMIN_EMAILS=admin@yourdomain.com

# --- Optional: /api/contact uses Nodemailer + Gmail ---
# Use an app password if2FA is on; see Google Account > App passwords
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your_app_password
